SUPABASE_URL=https://your-project.supabase.co

# New key format (sb_secret_…) — Supabase dashboard → Project Settings → API → Secret key.
# The legacy SUPABASE_SERVICE_ROLE_KEY is also accepted as a fallback.
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Public origin of the deployed snap (no trailing slash). Used in button targets.
SNAP_PUBLIC_BASE_URL=https://farcon-snap.vercel.app

# Local dev only — pnpm dev sets this to 1 automatically. Never set to 1 in production.
SKIP_JFS_VERIFICATION=0
