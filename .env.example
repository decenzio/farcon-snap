# Public base URL of your deployed snap (no trailing slash)
# Set this on your hosting provider. Leave empty for local dev.
SNAP_PUBLIC_BASE_URL=

# Port for local development (default: 3003)
PORT=3003

# Turso database credentials (required for persistent storage in production)
# Get these from https://turso.tech after creating a database
# Without these, the store uses in-memory (data resets on restart)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
